#include <iostream>
using namespace std;
int main()
{
	int a, b;
	int choice = -100;

	while (choice !=0)
	{
		
		//Menu
		cout << "1 - Add\n";
		cout << "2 - Subtract\n";
		cout << "0 - Exit\n";
		cout << "Choose: \n";
		cin >> choice;
		
		if (choice == 0)
		{
			cout << "Exiting program...." << endl;
		}
		else if (choice == 2)
		{
			cout << "Total is: " << a - b << endl;
		}
		else if (choice == 1)
		{
			cout << cout << "Total is: " << a + b << endl;
		}
		else
		{
			cout << "Invalid choice\n";
		}
		
		cout << "Enter first number: ";
		cin >> a;

		cout << "Enter second number: ";
		cin >> b;

		cout << "_____________________" << endl;
	}







	return 0;


}